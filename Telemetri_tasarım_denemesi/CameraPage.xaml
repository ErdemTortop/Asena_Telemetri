<Page x:Class="Telemetri_tasarım_denemesi.CameraPage"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
      xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
      xmlns:local="clr-namespace:Telemetri_tasarım_denemesi"
      Loaded="CameraPage_Loaded"
      Unloaded="CameraPage_Unloaded"
      mc:Ignorable="d" 
      FontFamily="Segoe UI Semibold"
      d:DesignHeight="800" d:DesignWidth="1300"
      Title="CameraPage">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="100"/>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Border CornerRadius="20"  BorderThickness="0" Height="70" Width="540" HorizontalAlignment="Left" Margin="10,15,0,15"/>
        <TextBlock Foreground="#E2E8F0" HorizontalAlignment="Left"  TextWrapping="Wrap" Text="   Asena Telemetri Veri Kaydetme Ekranı" VerticalAlignment="Center" FontSize="30"/>
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition Width="400"/>
                <ColumnDefinition Width="50"/>
                <ColumnDefinition />
                <ColumnDefinition Width="50"/>
            </Grid.ColumnDefinitions>

            <Grid Grid.Row="1" Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="50"/>
                    <RowDefinition Height="100"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>



                <Border Background="#262835" CornerRadius="20"  BorderThickness="0" Grid.Row="1" Width="200" Height="80">
                    <Button Style="{StaticResource OrangeHoverButton}" x:Name="KayıtStartButon" Click="Kayit_Click" >
                        <TextBlock  TextWrapping="Wrap" Foreground="#E2E8F0" Text="Kaydı Başlat" FontSize="20" FontWeight="Light"/>
                    </Button>
                </Border>

                <Border Background="#262835" CornerRadius="20" BorderThickness="0" Grid.Row="3" Width="200" Height="80">
                    <Button Style="{StaticResource OrangeHoverButton}" x:Name="KayıtFinishButon" Click="Stop_Click" >
                        <TextBlock  Grid.Row="3" TextWrapping="Wrap" Foreground="#E2E8F0" Text="Kaydı Durdur" FontSize="20" FontWeight="Light"/>
                    </Button>
                </Border>

                <Border Background="#262835" BorderThickness="0" CornerRadius="20" Grid.Row="5" Width="200" Height="80">
                    <Button Style="{StaticResource OrangeHoverButton}" x:Name="KayıtFolderButon" Click="File_Click"  >
                        <TextBlock Grid.Row="3" TextWrapping="Wrap" Foreground="#E2E8F0" Text="Kayıt Klasörünü Aç" FontSize="20" FontWeight="Light"/>
                    </Button>
                </Border>

                <Border Background="#262835" BorderThickness="0" CornerRadius="20" Grid.Row="7" Width="200" Height="80">
                    <Button Style="{StaticResource OrangeHoverButton}" x:Name="FolderTemizleButon" Click="FileTemizle_Click" >
                        <TextBlock Grid.Row="3" TextWrapping="Wrap" Foreground="#E2E8F0" Text="En Son Kaydı Temizle " FontSize="20" FontWeight="Light"/>
                    </Button>
                </Border>

            </Grid>

            <Grid Grid.Column="3">

                <Grid.RowDefinitions>
                    <RowDefinition/>
                    <RowDefinition Height="150"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="225"/>
                        <ColumnDefinition Width="300"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border BorderBrush="#3D3D4E" BorderThickness="1" Grid.Row="1" Grid.Column="1" Background="#262835" CornerRadius="20" Height="50" Width="100 " HorizontalAlignment="Left">
                        <TextBlock TextWrapping="Wrap" Foreground="#E2E8F0" Text="Kayıt Durumu" FontSize="16" HorizontalAlignment="Center" FontWeight="Light"/>
                    </Border>

                    <Border BorderBrush="#3D3D4E" BorderThickness="1" Grid.Row="2" Grid.Column="2" CornerRadius="20" Background="#262835" Width="200" Height="80" HorizontalAlignment="Right">
                        <Label  x:Name="KayıtDurumuRenk" Background="#E05C5C" HorizontalAlignment="Center" VerticalAlignment="Center" Width="100" Height="40" />
                    </Border>

                </Grid>

                <Border Background="#262835" BorderThickness="1" BorderBrush="#3D3D4E"  CornerRadius="20" Width="525" Height="350">

                    <TextBox Width="475" Height="300" x:Name="KayitTextBox" BorderThickness="0" Background="Transparent" FontSize="16" Foreground="#E2E8F0" TextWrapping="Wrap" AcceptsReturn="True" VerticalScrollBarVisibility="Auto" IsReadOnly="True"/>

                </Border>



            </Grid>
        </Grid>




    </Grid>
</Page>
